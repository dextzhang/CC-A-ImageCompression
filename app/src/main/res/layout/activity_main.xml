<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_width"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="超超无损相册压缩"
            android:textColor="@color/text_primary"
            android:textSize="22sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="压缩照片并完整保留拍摄时间与 EXIF 信息"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:gravity="center"
            android:layout_marginBottom="24dp"/>

        <!-- Preview Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="220dp"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="@color/card_dark"
            app:cardElevation="0dp"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:baselineAligned="false">

                <!-- Original Preview -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="原图"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp"
                        android:layout_marginBottom="6dp"/>

                    <ImageView
                        android:id="@+id/imgOriginal"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerInside"
                        android:contentDescription="原图预览"
                        android:src="@android:drawable/ic_menu_gallery"/>
                </LinearLayout>

                <View
                    android:layout_width="1dp"
                    android:layout_height="match_parent"
                    android:background="@color/border_color"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="20dp"/>

                <!-- Compressed Preview -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="压缩后"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp"
                        android:layout_marginBottom="6dp"/>

                    <ImageView
                        android:id="@+id/imgCompressed"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerInside"
                        android:contentDescription="压缩图预览"
                        android:src="@android:drawable/ic_menu_gallery"/>
                </LinearLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Stats Grid -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp"
            android:gap="12dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@color/card_dark"
                android:padding="12dp"
                android:gravity="center"
                android:layout_marginEnd="6dp">
                <TextView
                    android:id="@+id/txtOriginalSize"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="-- MB"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:textStyle="bold"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="原始大小"
                    android:textColor="@color/text_secondary"
                    android:textSize="10sp"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@color/card_dark"
                android:padding="12dp"
                android:gravity="center"
                android:layout_marginStart="6dp">
                <TextView
                    android:id="@+id/txtCompressedSize"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="-- MB"
                    android:textColor="@color/gold_primary"
                    android:textSize="15sp"
                    android:textStyle="bold"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="压缩后大小"
                    android:textColor="@color/text_secondary"
                    android:textSize="10sp"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>

        </LinearLayout>

        <!-- Controls Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/card_dark"
            android:padding="20dp"
            android:layout_marginBottom="24dp">

            <!-- Quality Control -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="4dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="压缩质量"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp"/>
                <TextView
                    android:id="@+id/txtQualityVal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="80%"
                    android:textColor="@color/gold_primary"
                    android:textSize="13sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <SeekBar
                android:id="@+id/sbQuality"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="100"
                android:progress="80"
                android:layout_marginBottom="16dp"
                android:thumbTint="@color/gold_primary"
                android:progressTint="@color/gold_primary"/>

            <!-- Scale Control -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="4dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="尺寸缩放"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp"/>
                <TextView
                    android:id="@+id/txtScaleVal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="100%"
                    android:textColor="@color/gold_primary"
                    android:textSize="13sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <SeekBar
                android:id="@+id/sbScale"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="100"
                android:progress="100"
                android:thumbTint="@color/gold_primary"
                android:progressTint="@color/gold_primary"/>

        </LinearLayout>

        <!-- Actions -->
        <Button
            android:id="@+id/btnSelect"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="🖼️ 选择相册照片"
            android:textColor="@color/black"
            android:backgroundTint="@color/gold_primary"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:cornerRadius="14dp"
            android:layout_marginBottom="12dp"
            android:textStyle="bold"/>

        <Button
            android:id="@+id/btnCompressSave"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="💾 压缩并保存至相册"
            android:textColor="@color/text_primary"
            android:backgroundTint="#2A2A2A"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:cornerRadius="14dp"
            android:textStyle="bold"
            android:enabled="false"/>

    </LinearLayout>
</ScrollView>
