<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0C"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp">

        <!-- Header Block -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="超超极速批量压缩"
                android:textColor="#FFD700"
                android:textSize="24sp"
                android:textStyle="bold"
                android:letterSpacing="0.05"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="多图并行压缩 • 完美保留拍摄时间与完整 EXIF"
                android:textColor="#88888E"
                android:textSize="11sp"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <!-- Main Photo Work Area -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardBackgroundColor="#141416"
            app:cardElevation="0dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp"
                android:minHeight="280dp">

                <!-- 1. Empty State Area -->
                <LinearLayout
                    android:id="@+id/layEmptyState"
                    android:layout_width="match_parent"
                    android:layout_height="260dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:visibility="visible">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📸"
                        android:textSize="50sp"
                        android:layout_marginBottom="12dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="相册工作区为空"
                        android:textColor="#EAEAEA"
                        android:textSize="15sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="点击下方按钮导入照片，压缩后点击单项可预览对比"
                        android:textColor="#66666F"
                        android:textSize="11sp"
                        android:layout_marginTop="6dp"/>
                </LinearLayout>

                <!-- 2. Grid RecyclerView -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvImages"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    android:visibility="gone"
                    android:scrollbars="vertical"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Dynamic Overall Batch Progress Bar -->
        <LinearLayout
            android:id="@+id/layBatchProgress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#141416"
            android:padding="14dp"
            android:layout_marginBottom="16dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="6dp">
                <TextView
                    android:id="@+id/txtBatchProgressLabel"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="正在批量压缩 (0/0)..."
                    android:textColor="#EAEAEA"
                    android:textSize="12sp"
                    android:textStyle="bold"/>
                <TextView
                    android:id="@+id/txtBatchPercent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0%"
                    android:textColor="#FFD700"
                    android:textSize="12sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <ProgressBar
                android:id="@+id/pbBatchProgress"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:max="100"
                android:progress="0"
                android:progressTint="#FFD700"
                android:progressBackgroundTint="#333333"/>
        </LinearLayout>

        <!-- Summary Panel (Total size savings display) -->
        <LinearLayout
            android:id="@+id/layStatsSummary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1F1F24"
            android:padding="14dp"
            android:layout_marginBottom="16dp"
            android:visibility="gone">
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📊 压缩汇总报告"
                android:textColor="#FFD700"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/txtSummarySavings"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="原始总大小: -- MB -> 压缩后: -- MB (节省 --%)"
                android:textColor="#EAEAEA"
                android:textSize="12sp"/>
        </LinearLayout>

        <!-- Compression Settings Control Panel -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardBackgroundColor="#141416"
            app:cardElevation="0dp"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Quality Slider -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="4dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="压缩画质"
                        android:textColor="#CCCCCC"
                        android:textSize="13sp"/>
                    <TextView
                        android:id="@+id/txtQualityVal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="80%"
                        android:textColor="#FFD700"
                        android:textSize="13sp"
                        android:textStyle="bold"/>
                </LinearLayout>

                <SeekBar
                    android:id="@+id/sbQuality"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="100"
                    android:progress="80"
                    android:layout_marginBottom="16dp"
                    android:thumbTint="#FFD700"
                    android:progressTint="#FFD700"/>

                <!-- Scale Slider -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="4dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="尺寸缩放"
                        android:textColor="#CCCCCC"
                        android:textSize="13sp"/>
                    <TextView
                        android:id="@+id/txtScaleVal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="100%"
                        android:textColor="#FFD700"
                        android:textSize="13sp"
                        android:textStyle="bold"/>
                </LinearLayout>

                <SeekBar
                    android:id="@+id/sbScale"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="100"
                    android:progress="100"
                    android:layout_marginBottom="16dp"
                    android:thumbTint="#FFD700"
                    android:progressTint="#FFD700"/>

                <!-- Presets Button Group -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="快速预设方案"
                    android:textColor="#888888"
                    android:textSize="11sp"
                    android:layout_marginBottom="8dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="16dp">

                    <Button
                        android:id="@+id/btnPresetUltra"
                        style="?android:attr/buttonBarButtonStyle"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:text="超清"
                        android:textColor="#FFD700"
                        android:backgroundTint="#242428"
                        android:textSize="11sp"
                        android:layout_marginEnd="4dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:padding="0dp"/>

                    <Button
                        android:id="@+id/btnPresetHigh"
                        style="?android:attr/buttonBarButtonStyle"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:text="高清"
                        android:textColor="#FFD700"
                        android:backgroundTint="#242428"
                        android:textSize="11sp"
                        android:layout_marginHorizontal="2dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:padding="0dp"/>

                    <Button
                        android:id="@+id/btnPresetStandard"
                        style="?android:attr/buttonBarButtonStyle"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:text="普通"
                        android:textColor="#FFD700"
                        android:backgroundTint="#242428"
                        android:textSize="11sp"
                        android:layout_marginHorizontal="2dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:padding="0dp"/>

                    <Button
                        android:id="@+id/btnPresetMax"
                        style="?android:attr/buttonBarButtonStyle"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:text="极致"
                        android:textColor="#FFD700"
                        android:backgroundTint="#242428"
                        android:textSize="11sp"
                        android:layout_marginStart="4dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:padding="0dp"/>
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#222222"
                    android:layout_marginBottom="8dp"/>

                <!-- Keep EXIF Toggle Switch -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="保留 EXIF 元数据 (拍摄时间、GPS地点、相机等)"
                        android:textColor="#CCCCCC"
                        android:textSize="12sp"/>

                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/swKeepExif"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true"
                        app:thumbTint="#FFD700"
                        app:trackTint="#665000"/>
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Big Buttons Panel -->
        <Button
            android:id="@+id/btnSelect"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="➕ 导入多张相册照片"
            android:textColor="#000000"
            android:backgroundTint="#FFD700"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:cornerRadius="14dp"
            android:layout_marginBottom="12dp"
            android:textStyle="bold"
            android:textSize="14sp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <Button
                android:id="@+id/btnClear"
                android:layout_width="90dp"
                android:layout_height="52dp"
                android:text="🧹 清空"
                android:textColor="#FF5555"
                android:backgroundTint="#251616"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:cornerRadius="14dp"
                android:layout_marginEnd="8dp"
                android:textStyle="bold"
                android:visibility="gone"/>

            <Button
                android:id="@+id/btnCompress"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:text="⚡ 开始批量压缩"
                android:textColor="#FFFFFF"
                android:backgroundTint="#242428"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:cornerRadius="14dp"
                android:textStyle="bold"
                android:textSize="14sp"
                android:enabled="false"/>
        </LinearLayout>

        <!-- Separate Save to Gallery Button (Activated only when compression is completed) -->
        <Button
            android:id="@+id/btnSaveToGallery"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="💾 保存全部到相册"
            android:textColor="#FFFFFF"
            android:backgroundTint="#1F1F24"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:cornerRadius="14dp"
            android:textStyle="bold"
            android:textSize="14sp"
            android:enabled="false"
            android:layout_marginBottom="24dp"/>

    </LinearLayout>
</ScrollView>
