<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp">

        <!-- Header Block -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="超图压缩"
                android:textColor="@color/text_primary"
                android:textSize="26sp"
                android:textStyle="bold"
                android:letterSpacing="0.06"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="多图并行压缩 • 完美保留拍摄时间与完整 EXIF"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:layout_marginTop="5dp"/>
        </LinearLayout>

        <!-- Work Area Header (Left: Import "+", Right: Clear "✕") -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:gravity="center_vertical"
            android:paddingHorizontal="4dp">

            <Button
                android:id="@+id/btnSelect"
                style="?android:attr/buttonBarButtonStyle"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_alignParentStart="true"
                android:text="➕ 导入照片"
                android:textColor="@color/text_primary"
                android:background="@drawable/bg_glass_btn_gold"
                android:textSize="12sp"
                android:textStyle="bold"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:paddingHorizontal="14dp"
                app:cornerRadius="14dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="照片工作队列"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:textStyle="bold"/>

            <Button
                android:id="@+id/btnClear"
                style="?android:attr/buttonBarButtonStyle"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_alignParentEnd="true"
                android:text="✕ 清空"
                android:textColor="#C29F9A"
                android:background="@drawable/bg_glass_btn_red"
                android:textSize="12sp"
                android:textStyle="bold"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:paddingHorizontal="14dp"
                android:visibility="gone"
                app:cornerRadius="14dp"/>
        </RelativeLayout>

        <!-- Main Photo Work Area -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardBackgroundColor="@android:color/transparent"
            app:cardElevation="0dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp"
                android:background="@drawable/bg_glass_card"
                android:minHeight="280dp">

                <!-- 1. Empty State Area -->
                <LinearLayout
                    android:id="@+id/layEmptyState"
                    android:layout_width="match_parent"
                    android:layout_height="260dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:visibility="visible">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📸"
                        android:textSize="50sp"
                        android:layout_marginBottom="12dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="相册工作区为空"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="点击左上角按钮导入照片，压缩后点击单项可预览对比"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp"
                        android:layout_marginTop="6dp"/>
                </LinearLayout>

                <!-- 2. Grid RecyclerView -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvImages"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    android:visibility="gone"
                    android:scrollbars="vertical"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Dynamic Overall Batch Progress Bar -->
        <LinearLayout
            android:id="@+id/layBatchProgress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_glass_card"
            android:padding="14dp"
            android:layout_marginBottom="16dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="6dp">
                <TextView
                    android:id="@+id/txtBatchProgressLabel"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="正在批量压缩 (0/0)..."
                    android:textColor="@color/text_primary"
                    android:textSize="12sp"
                    android:textStyle="bold"/>
                <TextView
                    android:id="@+id/txtBatchPercent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0%"
                    android:textColor="@color/gold_primary"
                    android:textSize="12sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <ProgressBar
                android:id="@+id/pbBatchProgress"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:max="100"
                android:progress="0"
                android:progressTint="@color/gold_primary"
                android:progressBackgroundTint="@color/border_color"/>
        </LinearLayout>

        <!-- Summary Panel -->
        <LinearLayout
            android:id="@+id/layStatsSummary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_glass_card"
            android:padding="14dp"
            android:layout_marginBottom="16dp"
            android:visibility="gone">
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📊 压缩汇总报告"
                android:textColor="@color/gold_primary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/txtSummarySavings"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="原始总大小: -- MB -> 压缩后: -- MB (节省 --%)"
                android:textColor="@color/text_primary"
                android:textSize="12sp"/>
        </LinearLayout>

        <!-- Compression Settings Control Panel -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardBackgroundColor="@android:color/transparent"
            app:cardElevation="0dp"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_glass_card"
                android:padding="16dp">

                <!-- Quality Slider -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="4dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="压缩画质"
                        android:textColor="@color/text_primary"
                        android:textSize="13sp"/>
                    <TextView
                        android:id="@+id/txtQualityVal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="80%"
                        android:textColor="@color/gold_primary"
                        android:textSize="13sp"
                        android:textStyle="bold"/>
                </LinearLayout>

                <SeekBar
                    android:id="@+id/sbQuality"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="100"
                    android:progress="80"
                    android:layout_marginBottom="16dp"
                    android:thumbTint="@color/gold_primary"
                    android:progressTint="@color/gold_primary"/>

                <!-- Scale Slider -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="4dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="尺寸缩放"
                        android:textColor="@color/text_primary"
                        android:textSize="13sp"/>
                    <TextView
                        android:id="@+id/txtScaleVal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="100%"
                        android:textColor="@color/gold_primary"
                        android:textSize="13sp"
                        android:textStyle="bold"/>
                </LinearLayout>

                <SeekBar
                    android:id="@+id/sbScale"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="100"
                    android:progress="100"
                    android:layout_marginBottom="16dp"
                    android:thumbTint="@color/gold_primary"
                    android:progressTint="@color/gold_primary"/>

                <!-- Presets Button Group -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="快速预设方案"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:layout_marginBottom="8dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="16dp">

                    <Button
                        android:id="@+id/btnPresetUltra"
                        style="?android:attr/buttonBarButtonStyle"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:text="超清"
                        android:textColor="@color/text_primary"
                        android:background="@drawable/bg_glass_btn_neutral"
                        android:textSize="11sp"
                        android:layout_marginEnd="4dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:padding="0dp"/>

                    <Button
                        android:id="@+id/btnPresetHigh"
                        style="?android:attr/buttonBarButtonStyle"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:text="高清"
                        android:textColor="@color/text_primary"
                        android:background="@drawable/bg_glass_btn_neutral"
                        android:textSize="11sp"
                        android:layout_marginHorizontal="2dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:padding="0dp"/>

                    <Button
                        android:id="@+id/btnPresetStandard"
                        style="?android:attr/buttonBarButtonStyle"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:text="普通"
                        android:textColor="@color/text_primary"
                        android:background="@drawable/bg_glass_btn_neutral"
                        android:textSize="11sp"
                        android:layout_marginHorizontal="2dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:padding="0dp"/>

                    <Button
                        android:id="@+id/btnPresetMax"
                        style="?android:attr/buttonBarButtonStyle"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:text="极致"
                        android:textColor="@color/text_primary"
                        android:background="@drawable/bg_glass_btn_neutral"
                        android:textSize="11sp"
                        android:layout_marginStart="4dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:padding="0dp"/>
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/border_color"
                    android:layout_bottom="8dp"
                    android:layout_marginBottom="8dp"/>

                <!-- Keep EXIF Toggle Switch -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="保留 EXIF 元数据 (拍摄时间、GPS地点、相机等)"
                        android:textColor="@color/text_primary"
                        android:textSize="12sp"/>

                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/swKeepExif"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true"
                        app:thumbTint="@color/gold_primary"
                        app:trackTint="@color/gold_accent"/>
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Big Action Buttons Panel -->
        <Button
            android:id="@+id/btnCompress"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="⚡ 开始批量压缩"
            android:textColor="@color/text_primary"
            android:background="@drawable/bg_glass_btn_gold"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:cornerRadius="14dp"
            android:layout_marginBottom="12dp"
            android:textStyle="bold"
            android:textSize="14sp"
            android:enabled="false"/>

        <Button
            android:id="@+id/btnSaveToGallery"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="💾 保存全部到相册"
            android:textColor="@color/text_primary"
            android:background="@drawable/bg_glass_btn_green"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:cornerRadius="14dp"
            android:textStyle="bold"
            android:textSize="14sp"
            android:enabled="false"
            android:layout_marginBottom="24dp"/>

    </LinearLayout>
</ScrollView>
