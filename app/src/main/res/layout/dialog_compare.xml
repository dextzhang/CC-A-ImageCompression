<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_dark"
    android:padding="16dp">

    <!-- Dialog Header -->
    <TextView
        android:id="@+id/txtDialogTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="图片压缩对比"
        android:textColor="@color/text_primary"
        android:textSize="16sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="16dp"
        android:ellipsize="middle"
        android:singleLine="true"/>

    <!-- Dual Image View Comparison Area -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:baselineAligned="false">

        <!-- Original Frame -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="@drawable/bg_glass_card"
            android:layout_marginEnd="6dp"
            android:padding="8dp">

            <TextView
                android:id="@+id/txtDialogOrgLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="原图 (载入中...)"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:gravity="center"
                android:layout_marginBottom="6dp"/>

            <ImageView
                android:id="@+id/imgDialogOriginal"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="fitCenter"
                android:contentDescription="原图"/>
        </LinearLayout>

        <!-- Compressed Frame -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="@drawable/bg_glass_card"
            android:layout_marginStart="6dp"
            android:padding="8dp">

            <TextView
                android:id="@+id/txtDialogCompLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="压缩后 (载入中...)"
                android:textColor="@color/gold_primary"
                android:textSize="11sp"
                android:gravity="center"
                android:layout_marginBottom="6dp"/>

            <ImageView
                android:id="@+id/imgDialogCompressed"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="fitCenter"
                android:contentDescription="压缩图"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Stat Description Summary -->
    <TextView
        android:id="@+id/txtDialogSummary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/text_primary"
        android:textSize="12sp"
        android:gravity="center"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="16dp"
        android:text="大小对比: -- -> -- (节省 --%)"/>

    <!-- Close Button -->
    <Button
        android:id="@+id/btnDialogClose"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="返回列表"
        android:textColor="@color/text_primary"
        android:background="@drawable/bg_glass_btn_gold"
        app:cornerRadius="12dp"
        android:textStyle="bold"/>

</LinearLayout>
