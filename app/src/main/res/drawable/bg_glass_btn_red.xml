<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape>
            <gradient
                android:startColor="#E6E2D0CD"
                android:endColor="#CCC4ACAB"
                android:angle="90"/>
            <corners android:radius="14dp"/>
            <stroke android:width="1dp" android:color="#FFE8DBDB"/>
        </shape>
    </item>
    <item>
        <shape>
            <gradient
                android:startColor="#FAF4EAEB"
                android:endColor="#E2E2D0CE"
                android:angle="90"/>
            <corners android:radius="14dp"/>
            <stroke android:width="1.5dp" android:color="#90EADAC6"/>
        </shape>
    </item>
</selector>
