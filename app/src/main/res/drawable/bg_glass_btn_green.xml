<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape>
            <gradient
                android:startColor="#E6D2DDD0"
                android:endColor="#CCBCC6B2"
                android:angle="90"/>
            <corners android:radius="14dp"/>
            <stroke android:width="1dp" android:color="#FFE2EAD8"/>
        </shape>
    </item>
    <item android:state_enabled="false">
        <shape>
            <solid android:color="#1AE2D5C0"/>
            <corners android:radius="14dp"/>
            <stroke android:width="1dp" android:color="#22E2D5C0"/>
        </shape>
    </item>
    <item>
        <shape>
            <gradient
                android:startColor="#FAF4ECE0"
                android:endColor="#E2E2D0C4"
                android:angle="90"/>
            <corners android:radius="14dp"/>
            <stroke android:width="1.5dp" android:color="#90EADABF"/>
        </shape>
    </item>
</selector>
