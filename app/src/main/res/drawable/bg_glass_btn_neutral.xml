<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape>
            <gradient
                android:startColor="#E6F5F2EA"
                android:endColor="#CCEBE7DF"
                android:angle="90"/>
            <corners android:radius="10dp"/>
            <stroke android:width="1dp" android:color="#FFFAF9F5"/>
        </shape>
    </item>
    <item>
        <shape>
            <gradient
                android:startColor="#E6FCFAF6"
                android:endColor="#99E6E2D9"
                android:angle="90"/>
            <corners android:radius="10dp"/>
            <stroke android:width="1dp" android:color="#80DFD8CC"/>
        </shape>
    </item>
</selector>
